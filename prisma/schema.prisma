generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  EDITOR
  FAN
}

enum CoverType {
  IMAGE
  VIDEO
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

enum MediaType {
  IMAGE
  AUDIO
  VIDEO
}

enum ContentBlockType {
  GALLERY
  AUDIO_PLAYER
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  firstName      String
  lastName       String   @default("")
  passwordHash   String
  role           Role     @default(ADMIN)
  avatarUrl      String?
  avatarPublicId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  articles   Article[]
  comments   Comment[]
  loginCodes LoginCode[]
  passwordChangeCodes PasswordChangeCode[]
  sessions   Session[]
}

model SiteSettings {
  id           String   @id @default("main")
  siteName     String   @default("stepansoukup.cz")
  logoUrl      String?
  logoPublicId String?
  facebookUrl  String?
  instagramUrl String?
  spotifyUrl   String?
  youtubeUrl   String?
  tiktokUrl    String?
  contactEmail String?
  updatedAt    DateTime @updatedAt
}

model LandingPageContent {
  slug      String   @id
  content   Json
  updatedAt DateTime @updatedAt
}

model LoginCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordChangeCode {
  id                  String    @id @default(cuid())
  userId              String
  codeHash            String
  pendingPasswordHash String
  attempts            Int       @default(0)
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  userAgent   String?
  ip          String?
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  expiresAt   DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RateLimit {
  key         String   @id
  attempts    Int      @default(0)
  windowStart DateTime @default(now())
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}

model Article {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  perex         String        @db.Text
  content       String?       @db.Text
  coverType          CoverType     @default(IMAGE)
  coverImageUrl      String?
  coverImagePublicId String?
  coverVideoUrl      String?
  coverVideoPublicId String?
  status             ArticleStatus @default(DRAFT)
  publishedAt   DateTime?
  scoreLegacy       Int?
  scorePracticality Int?
  scorePrice        Int?
  scoreSound        Int?
  scoreLook         Int?
  authorId      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  author      User           @relation(fields: [authorId], references: [id])
  articleTags ArticleTag[]
  contentBlocks ContentBlock[]
  media       Media[]
  comments    Comment[]
  gearLinks   ArticleGear[]
}

model Category {
  id       String @id @default(cuid())
  name     String
  slug     String @unique
  position Int    @default(0)

  gear Gear[]
}

model GearGroup {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Gear[]
}

model Gear {
  id                 String   @id @default(cuid())
  brand              String
  model              String
  categoryId         String
  note               String?  @db.Text
  boughtAt           DateTime?
  soldAt             DateTime?
  inDrawer           Boolean  @default(false)
  purchaseUrl        String?
  eshopUrl           String?
  listingUrl         String?
  coverImageUrl      String?
  coverImagePublicId String?
  containerId        String?
  sameModelGroupId   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  category       Category         @relation(fields: [categoryId], references: [id])
  container      Gear?            @relation("GearContainer", fields: [containerId], references: [id], onDelete: SetNull)
  containedGear  Gear[]           @relation("GearContainer")
  sameModelGroup GearGroup?       @relation(fields: [sameModelGroupId], references: [id], onDelete: SetNull)
  privateInfo    GearPrivateInfo?
  gigs           GearOnGig[]
  articleLinks   ArticleGear[]

  @@index([categoryId])
  @@index([containerId])
  @@index([sameModelGroupId])
}

model GearPrivateInfo {
  gearId        String  @id
  serial        String?
  purchasePrice Decimal? @db.Decimal(12, 2)
  sellPrice     Decimal? @db.Decimal(12, 2)
  sellerName    String?
  sellerPhone   String?
  sellerEmail   String?
  sellerCity    String?
  sellerFb      String?
  buyerName     String?
  buyerPhone    String?
  buyerEmail    String?
  buyerAddress  String?
  buyerFb       String?

  gear Gear @relation(fields: [gearId], references: [id], onDelete: Cascade)
}

model ArticleGear {
  articleId String
  gearId    String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  gear    Gear    @relation(fields: [gearId], references: [id], onDelete: Cascade)

  @@id([articleId, gearId])
  @@unique([gearId])
}

model Band {
  id   String @id @default(cuid())
  name String @unique

  gigs Gig[]
}

model Gig {
  id           String   @id @default(cuid())
  date         DateTime
  city         String
  place        String?
  name         String?
  bandId       String
  note         String?  @db.Text
  photosUrl    String?
  recordingUrl String?
  youtubeUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  band Band        @relation(fields: [bandId], references: [id])
  gear GearOnGig[]

  @@index([date])
  @@index([bandId])
}

model GearOnGig {
  gearId String
  gigId  String

  gear Gear @relation(fields: [gearId], references: [id], onDelete: Cascade)
  gig  Gig  @relation(fields: [gigId], references: [id], onDelete: Cascade)

  @@id([gearId, gigId])
  @@index([gigId])
}

model Tag {
  id   String @id @default(cuid())
  name String
  slug String @unique

  articleTags ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String

  article Article @relation(fields: [articleId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
}

model ContentBlock {
  id        String           @id @default(cuid())
  articleId String
  type      ContentBlockType
  createdAt DateTime         @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  media   Media[]

  @@index([articleId])
}

model Media {
  id        String    @id @default(cuid())
  articleId String
  blockId   String?
  type      MediaType
  url       String
  publicId  String
  caption   String?
  position  Int       @default(0)
  createdAt DateTime  @default(now())

  article Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  block   ContentBlock? @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([articleId, blockId])
}

model Comment {
  id         String        @id @default(cuid())
  articleId  String
  authorId   String?
  authorName String?
  body       String        @db.Text
  parentId   String?
  status     CommentStatus @default(PENDING)
  createdAt  DateTime      @default(now())

  article Article   @relation(fields: [articleId], references: [id])
  author  User?     @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentThread")
}

model ContactMessage {
  id          String    @id @default(cuid())
  name        String
  email       String
  subject     String?
  body        String    @db.Text
  read        Boolean   @default(false)
  emailSentAt DateTime?
  emailError  String?   @db.Text
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([read])
}
